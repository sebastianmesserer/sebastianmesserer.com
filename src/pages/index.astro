---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const essays = await getCollection('essays');
essays.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Sebastian Messerer"
  description="I write about the near-future of companies — how technological developments reshape the way organisations produce, coordinate, and evolve."
>
  <div class="homepage">
    <h1>Sebastian Messerer</h1>
    <p class="intro">
      I write about the near-future of companies — how technological developments reshape the way organisations produce, coordinate, and evolve.
    </p>

    <ul class="essay-list">
      {
        essays.map((essay) => (
          <li>
            <a href={`/essays/${essay.slug}`}>
              <div class="essay-list-title">{essay.data.title}</div>
              <div class="essay-list-date">
                {essay.data.date.toLocaleDateString('en-GB', {
                  month: 'long',
                  year: 'numeric',
                })}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
