---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  description: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, subtitle, date, description, headings } = Astro.props;

const h2Headings = headings.filter((h) => h.depth === 2);

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={`Sebastian Messerer — ${title}`}
  description={description}
  ogType="article"
  article={{
    author: 'Sebastian Messerer',
    datePublished: date.toISOString(),
    headline: title,
  }}
>
  <div class="essay-layout">
    <aside class="toc">
      <div class="toc-label">Contents</div>
      <ol>
        {
          h2Headings.map((h) => (
            <li>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))
        }
      </ol>
    </aside>

    <article class="essay">
      <h1 class="essay-title">{title}</h1>
      {subtitle && <p class="essay-subtitle">{subtitle}</p>}
      <p class="essay-date">{formattedDate}</p>

      <slot />

      <div class="essay-footer">
        <p>
          Sebastian Messerer is a Berlin-based Senior Content Strategist at Amazon, where he leads B2B partner content strategy across European markets and designs AI-driven content systems. Before Amazon, he spent a decade in video and content strategy for clients including Adobe, Allianz, and the Mori Art Museum in Tokyo, following an early career in film and television.
        </p>
        <p style="margin-top: 0.8rem;">
          <a href="mailto:sebastian@sebastianmesserer.com">sebastian@sebastianmesserer.com</a>
          &ensp;·&ensp;
          <a href="https://x.com/SRMesserer">X</a>
          &ensp;·&ensp;
          <a href="https://www.linkedin.com/in/sebastian-messerer/">LinkedIn</a>
        </p>
      </div>
    </article>
  </div>
</BaseLayout>

<script>
  // Build footnote tooltips from endnote content
  const supRefs = document.querySelectorAll('.essay sup[id^="fnref-"]');

  supRefs.forEach((sup) => {
    const id = sup.id.replace('fnref-', '');
    const fnSpan = document.getElementById(`fn-${id}`);
    if (!fnSpan) return;

    const wrapper = document.createElement('span');
    wrapper.className = 'footnote-ref';
    sup.parentNode.insertBefore(wrapper, sup);
    wrapper.appendChild(sup);

    const tooltip = document.createElement('span');
    tooltip.className = 'footnote-tooltip';
    tooltip.innerHTML = fnSpan.innerHTML;
    wrapper.appendChild(tooltip);
  });

  // Click/tap: first tap shows tooltip, second tap navigates to endnote
  document.addEventListener('click', (e) => {
    const supLink = e.target.closest('.footnote-ref > sup > a');
    if (supLink) {
      const ref = supLink.closest('.footnote-ref');
      if (!ref.classList.contains('tooltip-visible')) {
        e.preventDefault();
        document.querySelectorAll('.footnote-ref.tooltip-visible').forEach((el) =>
          el.classList.remove('tooltip-visible')
        );
        ref.classList.add('tooltip-visible');
        return;
      }
      return; // tooltip already visible — allow navigation
    }

    // Click outside tooltip → close all
    if (!e.target.closest('.footnote-tooltip')) {
      document.querySelectorAll('.footnote-ref.tooltip-visible').forEach((el) =>
        el.classList.remove('tooltip-visible')
      );
    }
  });

  // Highlight active TOC link based on scroll position
  const tocLinks = document.querySelectorAll('.toc a');
  const headings = document.querySelectorAll('.essay h2');

  if (tocLinks.length && headings.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            tocLinks.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
            });
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );

    headings.forEach((h) => observer.observe(h));
  }
</script>
